---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import SocialLink from "../../components/social/SocialLink.astro";
import { t } from "../../lib/i18n";
---

<BaseLayout title="Social — JTimes">
  <section class="max-w-2xl mx-auto px-6 pt-24 pb-16">
    <div class="hero-rule mb-6"></div>
    <h1 class="text-4xl md:text-5xl font-light tracking-tight text-ink mb-4">
      {t("en", "social.title")}
    </h1>
    <p class="text-muted mb-12 leading-relaxed font-light">
      {t("en", "social.followOn")}
    </p>

    <div class="space-y-2">
      <SocialLink
        platform={t("en", "social.instagram")}
        url="https://www.instagram.com/jtimes.visual/"
        description="Daily shots, behind the scenes, and stories."
        handle="@jtimes.visual"
        icon="instagram"
      />
      <SocialLink
        platform={t("en", "social.threads")}
        url="https://www.threads.net/@jtimes.visual"
        description="Thoughts on photography and creative process."
        handle="@jtimes.visual"
        icon="threads"
      />
      <SocialLink
        platform={t("en", "social.xiaohongshu")}
        url="https://xhslink.com/m/AoxlJiMZwSY"
        description="Photography tips, gear reviews, and travel notes."
        handle="JTimes_Visual"
        icon="xiaohongshu"
      />
    </div>
  </section>
</BaseLayout>
