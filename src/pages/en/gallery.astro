---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoGrid from "../../components/gallery/PhotoGrid.astro";
import FilterBar from "../../components/gallery/FilterBar.astro";
import Lightbox from "../../components/gallery/Lightbox.astro";
import { getPhotos, getSeriesFromPhotos } from "../../lib/photos";
import { t } from "../../lib/i18n";

const locale = "en";
const photos = await getPhotos(locale);
const series = getSeriesFromPhotos(photos);
---

<BaseLayout title="Gallery — James Lyu" description="Browse photography by series — Hong Kong, Japan, and beyond.">
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16">
    <div class="hero-rule mb-6"></div>
    <h1 class="text-4xl md:text-5xl font-light tracking-tight text-ink">
      {t("en", "nav.gallery")}
    </h1>
    <div class="mt-10">
      <FilterBar locale="en" series={series} />
      <PhotoGrid photos={photos} />
      <Lightbox photos={photos} />
    </div>
  </section>
</BaseLayout>
