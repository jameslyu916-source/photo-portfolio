---
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoGrid from "../../components/gallery/PhotoGrid.astro";
import { getFeaturedPhotos } from "../../lib/photos";

const locale = "en";
const featured = await getFeaturedPhotos(locale);
---

<BaseLayout title="JTimes — Photography" description="Light, multiplied by time. Photography by JTimes.">
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-32 pb-16 md:pt-48 md:pb-20">
    <p class="text-8xl md:text-9xl lg:text-[10rem] font-display text-ink leading-none tracking-tight select-none">
      J&times;
    </p>
    <p class="mt-6 md:mt-8 text-base md:text-lg text-muted max-w-lg leading-relaxed font-light">
      light, multiplied by time
    </p>
    <a
      href={getRelativeLocaleUrl("en", "gallery")}
      class="inline-block mt-8 px-5 py-2.5 text-sm text-muted
             border border-border/60 rounded-full
             hover:text-accent hover:border-accent/40 transition-colors"
    >
      view gallery &rarr;
    </a>
  </section>

  <!-- Featured photos -->
  {
    featured.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 pb-32">
        <PhotoGrid photos={featured} />
      </section>
    )
  }
</BaseLayout>
