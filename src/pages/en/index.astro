---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoGrid from "../../components/gallery/PhotoGrid.astro";
import { getPhotos } from "../../lib/photos";

const locale = "en";
const photos = await getPhotos(locale);
---

<BaseLayout title="James Lyu — Photography" description="Personal photography portfolio. Hong Kong, Japan, and beyond.">
  <section class="pt-16">
    <PhotoGrid photos={photos} />
  </section>
</BaseLayout>
