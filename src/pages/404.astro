---
import BaseLayout from "../components/layout/BaseLayout.astro";
---

<BaseLayout title="Page Not Found — JTimes">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-6 pt-24 pb-16 text-center">
    <h1 class="text-6xl font-light text-ink mb-4">404</h1>
    <p class="text-xl text-muted mb-2">Page not found</p>
    <p class="text-sm text-muted mb-8">找不到這個頁面</p>
    <a
      href="/en/"
      class="inline-block px-6 py-2 rounded-full bg-ink text-paper text-sm hover:bg-ink/90 transition-colors"
    >
      Back to Home / 返回首頁
    </a>
  </section>
</BaseLayout>
