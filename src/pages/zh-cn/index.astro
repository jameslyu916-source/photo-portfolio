---
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoCard from "../../components/gallery/PhotoCard.astro";
import { getFeaturedPhotos } from "../../lib/photos";

const locale = "zh-cn";
const featured = await getFeaturedPhotos(locale);
const showcase = featured.slice(0, 5);
---

<BaseLayout title="JTimes — 摄影" description="光，乘以时间。JTimes 摄影作品。">
  <section class="max-w-7xl mx-auto px-6 pt-32 pb-16 md:pt-48 md:pb-24">
    <div class="relative inline-block">
      <span
        class="text-[14rem] md:text-[18rem] leading-none font-light italic select-none"
        style="font-family: 'Cormorant Garamond', serif; font-weight: 300;"
      >
        J
      </span>

      <span
        id="hero-x"
        class="x-cycle-container absolute -top-1 -right-4 md:-right-8 text-[4rem] md:text-[5.5rem] leading-none select-none cursor-pointer"
        role="button"
        aria-label="點擊讓 x 彈跳"
      >
        <span class="absolute inset-0 x-cycle-1" style="font-family: 'Caveat', cursive;">x</span>
        <span class="absolute inset-0 x-cycle-2" style="font-family: 'Waiting for the Sunrise', cursive;">x</span>
        <span class="absolute inset-0 x-cycle-3" style="font-family: 'Nothing You Could Do', cursive;">x</span>
      </span>
    </div>

    <div class="hero-rule mt-12 md:mt-16 mb-6 md:mb-8"></div>
    <p class="text-sm md:text-base text-muted max-w-md leading-relaxed font-light">
      光，乘以時間
    </p>

    <a
      href={getRelativeLocaleUrl("zh-cn", "gallery")}
      class="inline-block mt-10 px-5 py-2.5 text-sm text-muted/80
             border border-border/50 rounded-full
             hover:text-accent hover:border-accent/40 transition-colors"
    >
      瀏覽作品 &rarr;
    </a>
  </section>

  {
    showcase.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 pb-32">
        {showcase.slice(0, 2).length > 0 && (
          <div class="grid grid-cols-2 gap-4 md:gap-6 mb-4 md:mb-6">
            {showcase.slice(0, 2).map((photo) => (
              <PhotoCard photo={photo} />
            ))}
          </div>
        )}

        {showcase.slice(2, 5).length > 0 && (
          <div class="grid grid-cols-3 gap-4 md:gap-6">
            {showcase.slice(2, 5).map((photo) => (
              <PhotoCard photo={photo} />
            ))}
          </div>
        )}
      </section>
    )
  }
</BaseLayout>

<script>
  const heroX = document.getElementById("hero-x");
  if (heroX) {
    heroX.addEventListener("click", () => {
      heroX.classList.remove("x-pop");
      void heroX.offsetWidth;
      heroX.classList.add("x-pop");
      heroX.addEventListener("animationend", () => {
        heroX.classList.remove("x-pop");
      }, { once: true });
    });
  }
</script>
