---
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoCard from "../../components/gallery/PhotoCard.astro";
import { getFeaturedPhotos } from "../../lib/photos";

const locale = "zh-cn";
const featured = await getFeaturedPhotos(locale);
const showcase = featured.slice(0, 5);
---

<BaseLayout title="JTimes — 摄影" description="光，乘以時間。JTimes 摄影作品。">
  <section class="relative max-w-7xl mx-auto px-6 pt-32 pb-16 md:pt-48 md:pb-24">
    <div class="relative inline-block">
      <span
        class="text-[14rem] md:text-[18rem] leading-none font-light italic select-none"
        style="font-family: 'Cormorant Garamond', serif; font-weight: 300;"
      >
        J
      </span>

      <span
        id="hero-x"
        class="x-cycle-container absolute -top-1 -right-4 md:-right-8 text-[4rem] md:text-[5.5rem] leading-none select-none cursor-pointer"
        role="button"
        aria-label="點擊讓 x 彈跳"
      >
        <span class="absolute inset-0 x-cycle-1" style="font-family: 'Caveat', cursive;">x</span>
        <span class="absolute inset-0 x-cycle-2" style="font-family: 'Waiting for the Sunrise', cursive;">x</span>
        <span class="absolute inset-0 x-cycle-3" style="font-family: 'Nothing You Could Do', cursive;">x</span>
      </span>
    </div>

    <div class="hero-rule mt-12 md:mt-16 mb-6 md:mb-8"></div>
    <p class="text-sm md:text-base text-muted max-w-md leading-relaxed font-light">
      光，乘以時間
    </p>

    <a
      href={getRelativeLocaleUrl("zh-cn", "gallery")}
      class="inline-block mt-10 px-5 py-2.5 text-sm text-muted/80
             border border-border/50 rounded-full
             hover:text-accent hover:border-accent/40 transition-colors"
    >
      瀏覽作品 &rarr;
    </a>

    <div
      class="hidden md:block absolute top-8 right-8 lg:right-16
             w-64 h-80 select-none pointer-events-none"
      style="
        background-image:
          linear-gradient(to right, rgba(125,155,118,0.1) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(125,155,118,0.1) 1px, transparent 1px);
        background-size: 20px 20px;
        mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
      "
      aria-hidden="true"
    ></div>

    <div class="hidden md:block absolute top-0 right-0 w-80 h-full select-none pointer-events-none" aria-hidden="true">
      <span class="absolute poetry-fade text-accent/25 top-12 right-12 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 0s;">light, multiplied…</span>
      <span class="absolute poetry-fade text-accent/20 top-32 right-6 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 4s;">between the click…</span>
      <span class="absolute poetry-fade text-accent/25 top-20 right-16 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 8s;">borrowed time…</span>
      <span class="absolute poetry-fade text-accent/20 top-48 right-8 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 12s;">fragments of…</span>
      <span class="absolute poetry-fade text-accent/25 top-16 right-4 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 16s;">before it dissolves…</span>
      <span class="absolute poetry-fade text-accent/20 top-36 right-20 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 20s;">the weight of a glance…</span>
      <span class="absolute poetry-fade text-accent/25 top-8 right-10 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 2s;">stillness, then…</span>
      <span class="absolute poetry-fade text-accent/20 top-44 right-14 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 6s;">shadows folding…</span>
      <span class="absolute poetry-fade text-accent/25 top-28 right-2 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 10s;">what the eye forgets…</span>
      <span class="absolute poetry-fade text-accent/20 top-52 right-18 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 14s;">almost nothing…</span>
      <span class="absolute poetry-fade text-accent/25 top-24 right-10 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 18s;">say they happened…</span>
      <span class="absolute poetry-fade text-accent/20 top-40 right-6 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 22s;">a shutter's breath…</span>
      <span class="absolute poetry-fade text-accent/25 top-56 right-12 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 1s;">half-remembered light…</span>
      <span class="absolute poetry-fade text-accent/20 top-18 right-16 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 5s;">caught between…</span>
      <span class="absolute poetry-fade text-accent/25 top-60 right-4 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 9s;">not to keep them…</span>
    </div>
  </section>

  {
    showcase.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 pb-32">
        {showcase.slice(0, 2).length > 0 && (
          <div class="grid grid-cols-2 gap-4 md:gap-6 mb-4 md:mb-6">
            {showcase.slice(0, 2).map((photo) => (
              <PhotoCard photo={photo} />
            ))}
          </div>
        )}

        {showcase.slice(2, 5).length > 0 && (
          <div class="grid grid-cols-3 gap-4 md:gap-6">
            {showcase.slice(2, 5).map((photo) => (
              <PhotoCard photo={photo} />
            ))}
          </div>
        )}
      </section>
    )
  }
</BaseLayout>

<script>
  const heroX = document.getElementById("hero-x");
  if (heroX) {
    heroX.addEventListener("click", () => {
      heroX.classList.remove("x-pop");
      void heroX.offsetWidth;
      heroX.classList.add("x-pop");
      heroX.addEventListener("animationend", () => {
        heroX.classList.remove("x-pop");
      }, { once: true });
    });
  }
</script>
