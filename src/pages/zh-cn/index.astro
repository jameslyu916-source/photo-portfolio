---
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoGrid from "../../components/gallery/PhotoGrid.astro";
import { getFeaturedPhotos } from "../../lib/photos";
import { t } from "../../lib/i18n";

const locale = "zh-cn";
const featuredPhotos = await getFeaturedPhotos(locale);
---

<BaseLayout title="James Lyu — 摄影作品集" description="个人摄影作品集，探索街头、风景与光影之间的故事。常驻香港与日本。">
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16 md:pt-36 md:pb-24">
    <h1 class="text-4xl md:text-6xl font-light tracking-tight text-ink leading-tight">
      {t("zh-cn", "home.heroTitle")}
    </h1>
    <p class="mt-4 text-lg md:text-xl text-muted max-w-2xl leading-relaxed">
      {t("zh-cn", "home.heroSubtitle")}
    </p>
    <a
      href={getRelativeLocaleUrl("zh-cn", "gallery")}
      class="inline-block mt-8 px-6 py-3 rounded-full bg-ink text-paper text-sm
             font-medium hover:bg-ink/85 transition-colors"
    >
      {t("zh-cn", "home.viewGallery")}
    </a>
  </section>

  {
    featuredPhotos.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 pb-24">
        <h2 class="text-sm font-medium text-muted uppercase tracking-widest mb-8">
          {t("zh-cn", "home.featured")}
        </h2>
        <PhotoGrid photos={featuredPhotos} />
      </section>
    )
  }
</BaseLayout>
