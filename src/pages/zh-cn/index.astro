---
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import FeaturedWall from "../../components/gallery/FeaturedWall.astro";
import FilmStrip from "../../components/gallery/FilmStrip.astro";
import { getFeaturedPhotos } from "../../lib/photos";

const locale = "zh-cn";
const featured = await getFeaturedPhotos(locale);
const showcase = featured;
---

<BaseLayout title="JTimes — 光，乘以時間" description="光，乘以時間。JTimes 攝影作品。">
  <section class="relative max-w-7xl mx-auto px-6 pt-20 pb-4 md:pt-32 md:pb-10">
    <!-- Flowing curved light lines -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none flow-lines"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <!-- Deep S-curve across the composition -->
      <path d="M -5,90 C 20,65 35,55 50,48 S 80,25 105,10" stroke="#7d9b76" stroke-width="0.1" fill="none" opacity="0.22" class="fl-1" />
      <!-- Wide wave from top-left to bottom-right -->
      <path d="M -5,15 C 30,45 55,60 105,95" stroke="#7d9b76" stroke-width="0.08" fill="none" opacity="0.18" class="fl-2" />
      <!-- C-curve wrapping through the gap between Jx and grid -->
      <path d="M 15,100 C 55,70 65,30 95,-5" stroke="#7d9b76" stroke-width="0.12" fill="none" opacity="0.2" class="fl-3" />
      <!-- Gentle meander through the middle -->
      <path d="M -5,55 C 25,35 40,50 55,40 S 70,20 105,5" stroke="#7d9b76" stroke-width="0.07" fill="none" opacity="0.16" class="fl-4" />
    </svg>

    <div class="relative inline-block">
      <span
        class="text-[14rem] md:text-[18rem] leading-none font-light italic select-none relative z-10"
        style="font-family: 'Cormorant Garamond', serif; font-weight: 300;"
      >
        J
      </span>

      <span
        id="hero-x"
        class="x-cycle-container absolute -top-1 -right-[4rem] md:-right-[5rem] text-[4rem] md:text-[5.5rem] leading-none select-none cursor-pointer grid"
        style="grid-template: 1fr / 1fr;"
        role="button"
        aria-label="點擊讓 x 彈跳"
      >
        <span class="x-cycle-1" style="font-family: 'Caveat', cursive; grid-area: 1 / 1;">x</span>
        <span class="x-cycle-2" style="font-family: 'Waiting for the Sunrise', cursive; grid-area: 1 / 1;">x</span>
        <span class="x-cycle-3" style="font-family: 'Nothing You Could Do', cursive; grid-area: 1 / 1;">x</span>
      </span>
    </div>

    <div class="hero-rule mt-12 md:mt-16 mb-6 md:mb-8"></div>
    <p class="text-sm md:text-base text-muted max-w-md leading-relaxed font-light">
      光，乘以時間
    </p>

    <a
      href={getRelativeLocaleUrl("zh-cn", "gallery")}
      class="inline-block mt-10 px-5 py-2.5 text-sm text-muted/80
             border border-border/50 rounded-full
             hover:text-accent hover:border-accent/40 transition-colors"
    >
      瀏覽作品 &rarr;
    </a>

    <!-- Scroll hint arrow -->
    <button
      id="scroll-hint"
      class="hidden md:block mt-6 mx-auto
             scroll-hint-arrow cursor-pointer select-none
             focus:outline-none focus-visible:opacity-100"
      aria-label="向下滑動查看照片"
    >
      <svg width="28" height="18" viewBox="0 0 28 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 2L14 14L26 2" stroke="#7d9b76" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Mobile grid + poetry (right of Jˣ, smaller version of desktop) -->
    <div
      class="md:hidden absolute top-20 right-0 w-28 h-56 select-none pointer-events-none"
      style="
        background-image:
          linear-gradient(to right, rgba(125,155,118,0.08) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(125,155,118,0.08) 1px, transparent 1px);
        background-size: 16px 16px;
        mask-image: radial-gradient(ellipse at center, black 35%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 75%);
      "
      aria-hidden="true"
    ></div>
    <div class="md:hidden absolute top-20 right-0 w-28 h-56 select-none pointer-events-none" aria-hidden="true">
      <span class="absolute poetry-fade text-accent/40 top-0 right-1 text-sm" style="font-family: 'Caveat', cursive; animation-delay: 0s;">light, multiplied…</span>
      <span class="absolute poetry-fade text-accent/35 top-[2rem] right-3 text-xs" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 5s;">between the click…</span>
      <span class="absolute poetry-fade text-accent/40 top-[4rem] right-0 text-sm" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 10s;">a shutter's breath…</span>
      <span class="absolute poetry-fade text-accent/30 top-[6.5rem] right-4 text-xs" style="font-family: 'Caveat', cursive; animation-delay: 14s;">stillness, then…</span>
      <span class="absolute poetry-fade text-accent/35 top-[9rem] right-1 text-sm" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 19s;">fragments of…</span>
      <span class="absolute poetry-fade text-accent/40 top-[11rem] right-2 text-xs" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 23s;">almost nothing…</span>
    </div>

    <div
      class="hidden md:block absolute top-4 right-4 lg:right-12
             w-80 h-[30rem] select-none pointer-events-none"
      style="
        background-image:
          linear-gradient(to right, rgba(125,155,118,0.1) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(125,155,118,0.1) 1px, transparent 1px);
        background-size: 20px 20px;
        mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
      "
      aria-hidden="true"
    ></div>

    <div class="hidden md:block absolute top-0 right-0 w-96 h-[30rem] select-none pointer-events-none" aria-hidden="true">
      <span class="absolute poetry-fade text-accent/35 top-0 right-16 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 0s;">light, multiplied…</span>
      <span class="absolute poetry-fade text-accent/30 top-[4rem] right-4 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 4s;">between the click…</span>
      <span class="absolute poetry-fade text-accent/35 top-[2rem] right-[18rem] text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 8s;">borrowed time…</span>
      <span class="absolute poetry-fade text-accent/30 top-[8rem] right-8 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 12s;">fragments of…</span>
      <span class="absolute poetry-fade text-accent/35 top-[3rem] right-2 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 16s;">before it dissolves…</span>
      <span class="absolute poetry-fade text-accent/30 top-[7rem] right-[20rem] text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 20s;">the weight of a glance…</span>
      <span class="absolute poetry-fade text-accent/35 top-[10rem] right-12 text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 2s;">stillness, then…</span>
      <span class="absolute poetry-fade text-accent/30 top-[1rem] right-10 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 6s;">shadows folding…</span>
      <span class="absolute poetry-fade text-accent/35 top-[12rem] right-2 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 10s;">what the eye forgets…</span>
      <span class="absolute poetry-fade text-accent/30 top-[9rem] right-[16rem] text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 14s;">almost nothing…</span>
      <span class="absolute poetry-fade text-accent/35 top-[5rem] right-14 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 18s;">say they happened…</span>
      <span class="absolute poetry-fade text-accent/30 top-[11rem] right-6 text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 22s;">a shutter's breath…</span>
      <span class="absolute poetry-fade text-accent/35 top-[6rem] right-[12rem] text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 1s;">half-remembered light…</span>
      <span class="absolute poetry-fade text-accent/30 top-[15rem] right-[14rem] text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 5s;">caught between…</span>
      <span class="absolute poetry-fade text-accent/35 top-[14rem] right-[8rem] text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 9s;">not to keep them…</span>
      <span class="absolute poetry-fade text-accent/25 top-[18rem] right-[10rem] text-2xl" style="font-family: 'Caveat', cursive; animation-delay: 13s;">the geometry of…</span>
      <span class="absolute poetry-fade text-accent/20 top-[22rem] right-4 text-3xl" style="font-family: 'Waiting for the Sunrise', cursive; animation-delay: 17s;">what the light caught…</span>
      <span class="absolute poetry-fade text-accent/25 top-[20rem] right-[16rem] text-xl" style="font-family: 'Nothing You Could Do', cursive; animation-delay: 21s;">drift, then dissolve…</span>
    </div>
  </section>

  {
    showcase.length > 0 && (
      <section id="featured" class="pb-20">
        <div class="mb-8 px-6">
          <div class="flex items-center gap-4 max-w-7xl mx-auto">
            <div class="h-px flex-1 bg-border/30"></div>
            <span class="text-muted/50 text-xs tracking-[0.2em] uppercase font-light select-none">Featured Work</span>
            <div class="h-px flex-1 bg-border/30"></div>
          </div>
        </div>

        <FeaturedWall photos={showcase} />

        <div class="text-center mt-10 px-6">
          <a
            href={getRelativeLocaleUrl("zh-cn", "gallery")}
            class="group inline-flex items-center gap-2 text-muted/60
                   hover:text-accent transition-colors"
            style="font-family: 'Caveat', cursive; font-size: 1.2rem;"
          >
            瀏覽全部作品
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
      </section>
    )
  }

  <FilmStrip photos={showcase} />
</BaseLayout>

<script>
  function initHome() {
    const heroX = document.getElementById("hero-x");
    const scrollHint = document.getElementById("scroll-hint");
    const featured = document.getElementById("featured");

    if (heroX && heroX.dataset.ready !== "true") {
      heroX.dataset.ready = "true";
      heroX.addEventListener("click", () => {
        heroX.classList.remove("x-pop");
        void heroX.offsetWidth;
        heroX.classList.add("x-pop");
        heroX.addEventListener("animationend", () => {
          heroX.classList.remove("x-pop");
        }, { once: true });
      });
    }

    if (scrollHint && featured && scrollHint.dataset.ready !== "true") {
      scrollHint.dataset.ready = "true";
      scrollHint.addEventListener("click", () => {
        featured.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    }
  }

  initHome();
  document.addEventListener("astro:page-load", initHome);
</script>
