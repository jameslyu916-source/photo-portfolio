---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import SocialLink from "../../components/social/SocialLink.astro";
import { t } from "../../lib/i18n";
---

<BaseLayout title="社交媒体 — JTimes">
  <section class="max-w-2xl mx-auto px-6 pt-24 pb-16">
    <div class="hero-rule mb-6"></div>
    <h1 class="text-4xl md:text-5xl font-light tracking-tight text-ink mb-4">
      {t("zh-cn", "social.title")}
    </h1>
    <p class="text-muted mb-12 leading-relaxed font-light">
      {t("zh-cn", "social.followOn")}
    </p>

    <div class="space-y-2">
      <SocialLink
        platform={t("zh-cn", "social.instagram")}
        url="https://www.instagram.com/jtimes.visual/"
        description="每日随拍、幕后花絮与故事。"
        handle="@jtimes.visual"
        icon="instagram"
      />
      <SocialLink
        platform={t("zh-cn", "social.threads")}
        url="https://www.threads.net/@jtimes.visual"
        description="关于摄影与创作过程的思考。"
        handle="@jtimes.visual"
        icon="threads"
      />
      <SocialLink
        platform={t("zh-cn", "social.xiaohongshu")}
        url="https://xhslink.com/m/AoxlJiMZwSY"
        description="摄影技巧、器材评测与旅行笔记。"
        handle="JTimes_Visual"
        icon="xiaohongshu"
      />
    </div>
  </section>
</BaseLayout>
