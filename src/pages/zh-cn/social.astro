---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import SocialLink from "../../components/social/SocialLink.astro";
import { t } from "../../lib/i18n";
---

<BaseLayout title="社交媒体 — James Lyu">
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-3xl md:text-4xl font-light tracking-tight text-ink mb-4">
      {t("zh-cn", "social.title")}
    </h1>
    <p class="text-muted mb-12 max-w-xl leading-relaxed">
      {t("zh-cn", "social.followOn")}
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <SocialLink
        platform={t("zh-cn", "social.instagram")}
        url="https://www.instagram.com/jtimes.visual/"
        description="每日随拍、幕后花絮与故事。"
        icon="&#x1F4F7;"
      />
      <SocialLink
        platform={t("zh-cn", "social.threads")}
        url="https://www.threads.net/@jtimes.visual"
        description="关于摄影与创作过程的思考。"
        icon="&#x1F9F5;"
      />
      <SocialLink
        platform={t("zh-cn", "social.xiaohongshu")}
        url="https://xhslink.com/m/AoxlJiMZwSY"
        description="小红书号：JTimes_Visual — 摄影技巧、器材评测与旅行笔记。"
        icon="&#x1F4D5;"
      />
    </div>
  </section>
</BaseLayout>
