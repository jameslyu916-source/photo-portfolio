---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { t } from "../../lib/i18n";

const locale = "zh-cn";

const platforms = [
  {
    name: t(locale, "social.instagram"),
    handle: "@jtimes.visual",
    url: "https://www.instagram.com/jtimes.visual/",
    icon: "instagram",
  },
  {
    name: t(locale, "social.threads"),
    handle: "@jtimes.visual",
    url: "https://www.threads.net/@jtimes.visual",
    icon: "threads",
  },
  {
    name: t(locale, "social.xiaohongshu"),
    handle: "JTimes_Visual",
    url: "https://xhslink.com/m/AoxlJiMZwSY",
    icon: "xiaohongshu",
  },
  {
    name: t(locale, "social.douyin"),
    handle: "JTimes.Visual",
    url: "https://v.douyin.com/Yg8VB9S5s4o/",
    icon: "douyin",
  },
];

const sizes = [
  "w-[160px] h-[160px] md:w-[215px] md:h-[215px]",
  "w-[155px] h-[155px] md:w-[180px] md:h-[180px]",
  "w-[165px] h-[165px] md:w-[230px] md:h-[230px]",
  "w-[160px] h-[160px] md:w-[195px] md:h-[195px]",
];

const offsets = [
  "md:mt-8",
  "md:mt-0",
  "md:mt-2",
  "md:mt-14",
];
---

<BaseLayout title="社交媒體 — JTimes">
  <section class="relative max-w-5xl mx-auto px-6 pt-24 pb-16 overflow-hidden">
    <!-- Manuscript grid background -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="
        background-image:
          linear-gradient(to right, rgba(125,155,118,0.05) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(125,155,118,0.05) 1px, transparent 1px);
        background-size: 24px 24px;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
      "
      aria-hidden="true"
    ></div>

    <!-- Header -->
    <div class="relative z-10">
      <div class="hero-rule mb-6"></div>
      <h1 class="text-4xl md:text-5xl font-light tracking-tight text-ink mb-3">
        {t(locale, "social.title")}
      </h1>
      <p class="text-muted mb-12 leading-relaxed font-light max-w-lg">
        {t(locale, "social.followOn")}
      </p>
    </div>

    <!-- Bubble constellation -->
    <div class="relative z-10 flex flex-wrap justify-center items-start gap-5 md:gap-6 mt-10 md:mt-12">
      {platforms.map((p, i) => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`bubble-card group flex flex-col items-center justify-center gap-2.5
                  ${sizes[i]} ${offsets[i]}
                  rounded-full
                  bg-paper/85 border border-border/20 shadow-sm
                  hover:scale-[1.08] hover:!z-10
                  transition-all duration-400`}
          style={`animation-delay: ${i * 120}ms;`}
        >
          <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center rounded-full
                      bg-muted/[0.04] text-muted/50 group-hover:text-accent
                      group-hover:bg-accent/[0.06] transition-colors duration-500">
            {p.icon === "instagram" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="18" cy="6" r="1" fill="currentColor" stroke="none"/></svg>
            )}
            {p.icon === "threads" && (
              <span class="text-xl font-medium">@</span>
            )}
            {p.icon === "xiaohongshu" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="1"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
            )}
            {p.icon === "douyin" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V6c1.5.8 3.5 1.3 5.5 1.3v3.2c-1.5 0-3-.4-4.5-1v8.5a3.5 3.5 0 11-1-2.5"/></svg>
            )}
          </div>

          <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors duration-500 leading-tight text-center">
            {p.name}
          </h3>

          <p class="text-xs text-muted/40 font-light -mt-1">{p.handle}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .bubble-card {
    opacity: 0;
    animation: bubble-in 0.6s ease-out both;
  }

  .bubble-card:hover {
    box-shadow: 0 0 36px rgba(125,155,118,0.16);
    border-color: rgba(125,155,118,0.3);
  }

  @keyframes bubble-in {
    from {
      opacity: 0;
      transform: scale(0.85) translateY(12px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>
