---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { t } from "../../lib/i18n";
---

<BaseLayout title="联系 — JTimes">
  <section class="max-w-2xl mx-auto px-6 pt-24 pb-16">
    <div class="hero-rule mb-6"></div>
    <h1 class="text-4xl md:text-5xl font-light tracking-tight text-ink mb-4">
      {t("zh-cn", "contact.title")}
    </h1>
    <p class="text-muted mb-12 leading-relaxed font-light">
      {t("zh-cn", "contact.content")}
    </p>

    <div class="space-y-2">
      <a
        href="mailto:james.lyu916@gmail.com"
        class="group flex items-center gap-5 p-5 border border-border/60 rounded-sm
               hover:border-accent/30 transition-colors duration-300"
      >
        <div class="w-10 h-10 flex items-center justify-center rounded-full
                    bg-muted/5 text-muted group-hover:text-accent group-hover:bg-accent/5
                    transition-colors duration-300">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors">郵箱</h3>
          <p class="text-xs text-muted mt-0.5">james.lyu916@gmail.com</p>
        </div>
        <span class="text-muted/40 text-xs group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-300 hidden sm:inline">&rarr;</span>
      </a>

      <a
        href="https://www.instagram.com/jtimes.visual/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 p-5 border border-border/60 rounded-sm
               hover:border-accent/30 transition-colors duration-300"
      >
        <div class="w-10 h-10 flex items-center justify-center rounded-full
                    bg-muted/5 text-muted group-hover:text-accent group-hover:bg-accent/5
                    transition-colors duration-300">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="18" cy="6" r="1" fill="currentColor" stroke="none"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors">Instagram</h3>
          <p class="text-xs text-muted mt-0.5">@jtimes.visual</p>
        </div>
        <span class="text-muted/40 text-xs group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-300 hidden sm:inline">&rarr;</span>
      </a>

      <a
        href="https://www.threads.net/@jtimes.visual"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 p-5 border border-border/60 rounded-sm
               hover:border-accent/30 transition-colors duration-300"
      >
        <div class="w-10 h-10 flex items-center justify-center rounded-full
                    bg-muted/5 text-muted group-hover:text-accent group-hover:bg-accent/5
                    transition-colors duration-300">
          <span class="text-base font-medium">@</span>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors">Threads</h3>
          <p class="text-xs text-muted mt-0.5">@jtimes.visual</p>
        </div>
        <span class="text-muted/40 text-xs group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-300 hidden sm:inline">&rarr;</span>
      </a>

      <a
        href="https://github.com/jameslyu916-source"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 p-5 border border-border/60 rounded-sm
               hover:border-accent/30 transition-colors duration-300"
      >
        <div class="w-10 h-10 flex items-center justify-center rounded-full
                    bg-muted/5 text-muted group-hover:text-accent group-hover:bg-accent/5
                    transition-colors duration-300">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 22v-4a4.8 4.8 0 00-1-3.5c3 0 6-2 6-5.5a4.3 4.3 0 00-.8-2.5 3.8 3.8 0 000-2.8s-1 0-3.5 1.3a12 12 0 00-6.4 0C7.8.7 6.8.7 6.8.7a3.8 3.8 0 000 2.8 4.3 4.3 0 00-.8 2.5c0 3.5 3 5.5 6 5.5a4.8 4.8 0 00-1 3.5v4"/><path d="M9 18c-4.5 1.5-4.5-2.5-6-3"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors">GitHub</h3>
          <p class="text-xs text-muted mt-0.5">jameslyu916-source</p>
        </div>
        <span class="text-muted/40 text-xs group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-300 hidden sm:inline">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>
