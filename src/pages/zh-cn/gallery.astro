---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import PhotoGrid from "../../components/gallery/PhotoGrid.astro";
import FilterBar from "../../components/gallery/FilterBar.astro";
import Lightbox from "../../components/gallery/Lightbox.astro";
import { getPhotos } from "../../lib/photos";
import { t } from "../../lib/i18n";

const locale = "zh-cn";
const photos = await getPhotos(locale);
---

<BaseLayout title="作品集 — James Lyu">
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-3xl md:text-4xl font-light tracking-tight text-ink">
      {t("zh-cn", "nav.gallery")}
    </h1>
    <div class="mt-8">
      <FilterBar locale="zh-cn" />
      <PhotoGrid photos={photos} />
      <Lightbox photos={photos} />
    </div>
  </section>
</BaseLayout>
