---
import { t, type Locale } from "../../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
---

<footer class="border-t border-border py-10 mt-32">
  <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted/70 font-light">
    <p>&copy; {new Date().getFullYear()} JTimes</p>
    <p>{t(locale, "footer.copyright")}</p>
  </div>
</footer>
