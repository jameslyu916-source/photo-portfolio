---
interface Props {
  title: string;
  description?: string;
  image?: string;
  locale: string;
  canonicalPath: string;
}

const {
  title,
  description = "Personal photography portfolio exploring landscapes, streets, and the spaces in between.",
  image,
  locale,
  canonicalPath,
} = Astro.props;

const site = Astro.site ?? "https://jameslyu.github.io";

// Swap locale in the path. Locale appears after the base prefix:
// e.g., /photo-portfolio/en/gallery/ → /photo-portfolio/zh-cn/gallery/
const swapLocale = (target: string) =>
  canonicalPath.replace(/\/(en|zh-cn)(\/|$)/, `/${target}$2`);

const canonicalURL = new URL(canonicalPath, site).href;
const enURL = new URL(swapLocale("en"), site).href;
const zhcnURL = new URL(swapLocale("zh-cn"), site).href;
const ogImage = image
  ? new URL(image, site).href
  : new URL("/social-preview.jpg", site).href;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="zh-CN" href={zhcnURL} />
<link rel="alternate" hreflang="x-default" href={enURL} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
