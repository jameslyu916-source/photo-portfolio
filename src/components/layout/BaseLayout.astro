---
import { ViewTransitions } from "astro:transitions";
import Analytics from "@vercel/analytics/astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import SEO from "./SEO.astro";
import "../../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const locale = Astro.currentLocale ?? "en";
const canonicalPath = Astro.url.pathname;
---

<!doctype html>
<html lang={locale === "zh-cn" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fafaf9" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Essential: body text, headings, logo serif — render-blocking -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Zen+Maru+Gothic:wght@400;500&family=Zen+Kaku+Gothic+New:wght@300;400;500&family=Noto+Sans+SC:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Handwriting: decorative only, async — non-render-blocking -->
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500&family=Waiting+for+the+Sunrise&family=Nothing+You+Could+Do&display=swap"
      rel="stylesheet"
      media="print" onload="this.media='all'"
    />
    <SEO
      title={title}
      description={description}
      image={image}
      locale={locale}
      canonicalPath={canonicalPath}
    />
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink">
    <Header />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
