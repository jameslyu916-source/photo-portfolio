---
import PhotoCard from "./PhotoCard.astro";
import type { Photo } from "../../lib/photos";

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
const shuffled = [...photos].sort(() => Math.random() - 0.5);
const mid = Math.ceil(shuffled.length / 2);
const row1 = shuffled.slice(0, mid);
const row2 = shuffled.slice(mid);
---

{
  photos.length > 0 && (
    <section class="featured-wall" aria-label="Featured photos">
      <!-- Row 1: scrolls left, taller rail -->
      <div class="featured-rail rail-tall">
        <div class="featured-rail-track" data-direction="left" data-speed="slow">
          {[...row1, ...row1].map((photo) => {
            const { image } = photo.data;
            return (
              <div
                class="featured-photo"
                style={`aspect-ratio: ${image.width} / ${image.height};`}
              >
                <PhotoCard photo={photo} />
              </div>
            );
          })}
        </div>
      </div>

      <!-- Row 2: scrolls right, shorter rail -->
      <div class="featured-rail rail-short">
        <div class="featured-rail-track" data-direction="right" data-speed="fast">
          {[...row2, ...row2].map((photo) => {
            const { image } = photo.data;
            return (
              <div
                class="featured-photo"
                style={`aspect-ratio: ${image.width} / ${image.height};`}
              >
                <PhotoCard photo={photo} />
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )
}

<style is:global>
  .featured-wall {
    position: relative;
    overflow: hidden;
    padding: 0.5rem 0;
    --gap: 0.375rem;
    --fade-w: 10vw;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black var(--fade-w),
      black calc(100% - var(--fade-w)),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black var(--fade-w),
      black calc(100% - var(--fade-w)),
      transparent 100%
    );
  }

  .featured-rail {
    overflow: hidden;
    margin-bottom: var(--gap);
  }
  .featured-rail:last-child {
    margin-bottom: 0;
  }

  .featured-rail-track {
    display: flex;
    align-items: center;
    gap: var(--gap);
  }

  .featured-rail-track[data-direction="left"] {
    transform: translateX(0);
  }

  .featured-rail-track[data-direction="right"] {
    transform: translateX(-50%);
  }

  /* Asymmetric rail heights */
  .rail-tall .featured-photo  { height: 34vh; }
  .rail-short .featured-photo { height: 24vh; }

  /* Different scroll speeds */
  .featured-rail-track[data-speed="slow"] {
    animation-duration: 90s;
  }
  .featured-rail-track[data-speed="fast"] {
    animation-duration: 55s;
  }

  .featured-rail-track[data-direction="left"] {
    animation-name: scroll-left;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }
  .featured-rail-track[data-direction="right"] {
    animation-name: scroll-right;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .featured-photo {
    flex-shrink: 0;
  }

  .featured-rail:hover .featured-rail-track {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scroll-right {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @media (max-width: 768px) {
    .rail-tall .featured-photo  { height: 20vh; }
    .rail-short .featured-photo { height: 16vh; }
    .featured-rail-track[data-speed="slow"] { animation-duration: 60s; }
    .featured-rail-track[data-speed="fast"] { animation-duration: 40s; }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-rail-track {
      animation: none !important;
    }
  }
</style>
