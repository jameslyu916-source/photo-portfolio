---
import type { Photo } from "../../lib/photos";
import LazyImage from "./LazyImage.astro";

interface Props {
  photo: Photo;
}

const { photo } = Astro.props;
const { image, title, location, series } = photo.data;
const slug = photo.id.split("/").pop()?.replace(".md", "");
---

<a
  href={`?photo=${slug}`}
  class="group block cursor-zoom-in"
  data-photo-id={slug}
  data-series={series ?? ""}
>
  <div
    class="relative overflow-hidden bg-muted/10"
    style={`aspect-ratio: ${image.width} / ${image.height};`}
  >
    <LazyImage
      image={image}
      alt={title}
      widths={[400, 800, 1200]}
      class="group-hover:scale-105 transition-transform duration-700 ease-out"
    />

    <!-- Hover overlay — refined, minimal -->
    <div
      class="absolute inset-0 bg-gradient-to-b from-ink/5 via-transparent to-ink/30
                  opacity-0 group-hover:opacity-100 transition-opacity duration-500
                  flex flex-col justify-end p-5"
    >
      <h3 class="text-white/90 text-sm font-medium leading-snug">{title}</h3>
      {location && (
        <p class="text-white/60 text-xs mt-0.5 font-light">{location}</p>
      )}
    </div>
  </div>
</a>
