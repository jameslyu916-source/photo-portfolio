---
import type { Photo } from "../../lib/photos";
import LazyImage from "./LazyImage.astro";

interface Props {
  photo: Photo;
  delay?: number;
}

const { photo, delay = 0 } = Astro.props;
const { image, title, location, series } = photo.data;
const slug = photo.id.split("/").pop()?.replace(".md", "");
---

<a
  class="group block cursor-zoom-in"
  data-photo-id={slug}
  data-series={series ?? ""}
  style={`aspect-ratio: ${image.width} / ${image.height}; animation-delay: ${delay}ms;`}
>
  <div class="relative overflow-hidden w-full h-full">
    <LazyImage
      image={image}
      alt={title}
      widths={[400, 800, 1200]}
      class="group-hover:scale-105 transition-transform duration-700 ease-out will-change-transform backface-hidden"
    />

    <div
      class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/50 to-transparent
                  opacity-0 group-hover:opacity-100 transition-opacity duration-500
                  flex flex-col justify-end p-5 pt-12 z-20 will-change-[opacity]"
    >
      {title && (
        <h3 class="text-white text-sm font-medium leading-snug">{title}</h3>
      )}
      {location && (
        <p class="text-white/70 text-xs mt-0.5 font-light">{location}</p>
      )}
    </div>
  </div>
</a>
