---
import { t, type Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
  series: string[];
}

const { locale, series } = Astro.props;

const items = [
  { key: "all", label: t(locale, "gallery.filterAll") },
  ...series.map((s) => ({ key: s, label: s })),
];
---

{items.length > 1 && (
  <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
    {items.map((item, i) => (
      <button
        data-filter={item.key}
        class={`filter-btn px-4 py-1.5 rounded-full text-sm transition-colors border
          bg-transparent text-muted border-border
          hover:text-ink hover:border-ink
          ${i === 0 ? "filter-active" : ""}`}
      >
        {item.label}
      </button>
    ))}
  </div>
)}

<script>
  function initFilterBar() {
    const filterBar = document.getElementById("filter-bar");
    if (!filterBar || filterBar.dataset.ready === "true") return;
    filterBar.dataset.ready = "true";

    let swapTimer: ReturnType<typeof setTimeout> | null = null;

    filterBar.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-filter]");
      if (!btn) return;

      filterBar.querySelectorAll(".filter-btn").forEach((b) => {
        b.classList.remove("filter-active");
      });
      btn.classList.add("filter-active");

      const filter = btn.dataset.filter;
      const gallery = document.querySelector(".grid-gallery");
      if (!gallery) return;

      // Cancel any in-progress swap
      if (swapTimer) clearTimeout(swapTimer);

      // Phase 1: fade all cards out
      gallery.classList.add("filtering");

      // Phase 2: swap display states while invisible
      swapTimer = setTimeout(() => {
        swapTimer = null;
        const cards = document.querySelectorAll("[data-series]");
        cards.forEach((card) => {
          const el = card as HTMLElement;
          const match = filter === "all" || el.dataset.series === filter;
          if (match) {
            el.style.display = "";
            el.classList.remove("filtered-out");
          } else {
            el.classList.add("filtered-out");
            el.style.display = "none";
          }
        });

        // Phase 3: fade visible cards in
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            gallery.classList.remove("filtering");
          });
        });
      }, 250);
    });
  }

  initFilterBar();
  document.addEventListener("astro:page-load", initFilterBar);
</script>
