---
import { t, type Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
  series: string[];
}

const { locale, series } = Astro.props;

const items = [
  { key: "all", label: t(locale, "gallery.filterAll") },
  ...series.map((s) => ({ key: s, label: s })),
];
---

{items.length > 1 && (
  <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
    {items.map((item, i) => (
      <button
        data-filter={item.key}
        class={`px-4 py-1.5 rounded-full text-sm transition-colors border
          ${i === 0
            ? "bg-ink text-paper border-ink"
            : "bg-transparent text-muted border-border hover:text-ink hover:border-ink"
          }`}
      >
        {item.label}
      </button>
    ))}
  </div>
)}

<script>
  function initFilterBar() {
    const filterBar = document.getElementById("filter-bar");
    if (!filterBar || filterBar.dataset.ready === "true") return;
    filterBar.dataset.ready = "true";

    filterBar.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-filter]");
      if (!btn) return;

      const active = "bg-ink text-paper border-ink";
      const inactive = "bg-transparent text-muted border-border";

      filterBar.querySelectorAll("[data-filter]").forEach((b) => {
        b.className = b.className.includes(active)
          ? b.className.replace(active, inactive)
          : b.className;
      });
      btn.className = btn.className.replace(inactive, active);

      const filter = btn.dataset.filter;
      document.querySelectorAll("[data-series]").forEach((card) => {
        const s = (card as HTMLElement).dataset.series;
        (card as HTMLElement).style.display =
          filter === "all" || s === filter ? "" : "none";
      });
    });
  }

  initFilterBar();
  document.addEventListener("astro:page-load", initFilterBar);
</script>
