---
import type { Photo } from "../../lib/photos";
import { getImage } from "astro:assets";

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

const photosData = await Promise.all(
  photos.map(async (photo) => {
    const large = await getImage({
      src: photo.data.image,
      width: 2400,
      format: "webp",
    });
    const thumb = await getImage({
      src: photo.data.image,
      width: 400,
      format: "webp",
    });
    return {
      id: photo.id.split("/").pop()?.replace(".md", ""),
      src: large.src,
      width: large.attributes.width ?? 2400,
      height: large.attributes.height ?? 1600,
      thumbnail: thumb.src,
      title: photo.data.title,
      description: photo.data.description ?? "",
      location: photo.data.location ?? "",
      camera: photo.data.camera ?? "",
      lens: photo.data.lens ?? "",
      settings: photo.data.settings ?? "",
    };
  }),
);

const photosJson = JSON.stringify(photosData);
---

<!-- Photoswipe container -->
<div class="pswp" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="pswp__bg"></div>
  <div class="pswp__scroll-wrap">
    <div class="pswp__container">
      <div class="pswp__item"></div>
      <div class="pswp__item"></div>
      <div class="pswp__item"></div>
    </div>
    <div class="pswp__ui pswp__ui--hidden">
      <div class="pswp__top-bar">
        <div class="pswp__counter"></div>
        <button class="pswp__button pswp__button--close" title="Close (Esc)"></button>
        <button class="pswp__button pswp__button--zoom" title="Zoom in/out"></button>
        <div class="pswp__preloader">
          <div class="pswp__preloader__icn">
            <div class="pswp__preloader__cut">
              <div class="pswp__preloader__donut"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="pswp__share-modal pswp__share-modal--hidden pswp__single-tap">
        <div class="pswp__share-tooltip"></div>
      </div>
      <button class="pswp__button pswp__button--arrow--left" title="Previous (arrow left)"></button>
      <button class="pswp__button pswp__button--arrow--right" title="Next (arrow right)"></button>
      <div class="pswp__caption">
        <div class="pswp__caption__center"></div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ photosJson }}>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/style.css";

  const photosData = JSON.parse(photosJson);

  const lightbox = new PhotoSwipeLightbox({
    gallery: "#photo-grid",
    children: "a[data-photo-id]",
    pswpModule: () => import("photoswipe"),
    preload: [1, 2],
  });

  lightbox.addFilter("itemData", (itemData, index) => {
    const data = photosData.find((p: { id: string }) => p.id === itemData.element?.dataset?.photoId);
    if (data) {
      return {
        src: data.src,
        width: data.width,
        height: data.height,
        title: data.title,
        alt: data.title,
        msrc: data.thumbnail,
        element: itemData.element,
      };
    }
    return itemData;
  });

  lightbox.on("uiRegister", function () {
    lightbox.pswp?.ui?.registerElement({
      name: "photo-info",
      order: 9,
      isButton: false,
      html: '<div class="pswp__photo-info"></div>',
      appendTo: "bar",
      onInit: (el) => {
        lightbox.pswp?.on("change", () => {
          const currSlide = lightbox.pswp?.currSlide;
          if (currSlide) {
            const data = photosData.find((p: { src: string }) => p.src === currSlide.data.src);
            if (data) {
              el.innerHTML = [
                data.location && `<span>${data.location}</span>`,
                data.camera && `<span>${data.camera}</span>`,
                data.lens && `<span>${data.lens}</span>`,
                data.settings && `<span>${data.settings}</span>`,
              ]
                .filter(Boolean)
                .join(" &middot; ");
            }
          }
        });
      },
    });
  });

  lightbox.init();
</script>

<style is:global>
  .pswp__photo-info {
    color: #ccc;
    font-size: 13px;
    padding-left: 10px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .pswp__caption__center {
    text-align: center !important;
    max-width: 600px;
    margin: 0 auto;
  }
</style>
