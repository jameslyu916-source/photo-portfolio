---
import type { Photo } from "../../lib/photos";
import { getImage } from "astro:assets";

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

const photosData = await Promise.all(
  photos.map(async (photo) => {
    const large = await getImage({
      src: photo.data.image,
      width: 2400,
      format: "webp",
    });
    const slug = photo.id.split("/").pop()?.replace(".md", "");
    return {
      slug,
      src: large.src,
      width: large.attributes.width ?? 2400,
      height: large.attributes.height ?? 1600,
      title: photo.data.title,
      series: photo.data.series ?? "",
    };
  }),
);

const photosJson = JSON.stringify(photosData);
---

<div
  id="film-strip"
  class="fixed inset-0 z-[999] flex flex-col bg-ink
         opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Blurred ambient backgrounds -->
  <img
    id="film-strip-bg-a"
    src=""
    alt=""
    class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700"
    style="filter: blur(70px) brightness(0.2) saturate(1.8); transform: scale(1.3);"
    aria-hidden="true"
  />
  <img
    id="film-strip-bg-b"
    src=""
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700"
    style="filter: blur(70px) brightness(0.2) saturate(1.8); transform: scale(1.3);"
    aria-hidden="true"
  />

  <!-- Floating edge arrows -->
  <button id="film-strip-prev" aria-label="Previous"
    class="film-strip-arrow left-4"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 6 9 12 15 18"></polyline>
    </svg>
  </button>
  <button id="film-strip-next" aria-label="Next"
    class="film-strip-arrow right-4"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>

  <!-- Horizontal scroll track -->
  <div
    id="film-strip-track"
    class="flex-1 flex items-center overflow-x-auto overflow-y-hidden scrollbar-none"
    style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding: 0 10vw;"
  >
    {photosData.map((p) => (
      <div
        id={`film-frame-${p.slug}`}
        class="film-frame flex-shrink-0 w-[80vw] h-full flex items-center justify-center"
        style="scroll-snap-align: center;"
      >
        <div class="film-frame-inner flex items-center justify-center w-full">
          <img
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
            data-src={p.src}
            alt={p.title}
            class="max-h-[80vh] max-w-full object-contain select-none"
          />
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom bar -->
  <div id="film-strip-bar" class="relative z-10 flex-shrink-0 flex items-center justify-between px-6 h-16 border-t border-white/[0.06] transition-opacity duration-500">
    <div class="flex items-center gap-4">
      <span id="film-strip-counter" class="text-white/60 text-sm font-light tracking-widest tabular-nums"
        style="font-family: 'Zen Kaku Gothic New', sans-serif;">1 / 1</span>
      <span id="film-strip-series"
        class="text-white/35 text-sm tracking-wide truncate max-w-[40vw]"
        style="font-family: 'Caveat', cursive; font-size: 1rem;">&nbsp;</span>
    </div>
    <button id="film-strip-close"
      class="flex items-center gap-2 text-white/50 hover:text-white transition-colors text-sm font-light tracking-wide"
      style="font-family: 'Zen Kaku Gothic New', sans-serif;"
      aria-label="Close"
    >
      Close
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="7" y1="7" x2="17" y2="17" />
        <line x1="17" y1="7" x2="7" y2="17" />
      </svg>
    </button>
  </div>
</div>

<script define:vars={{ photosJson }}>
  const photosData = JSON.parse(photosJson);
  let overlay, track, closeBtn, prevBtn, nextBtn, counter, seriesEl, bgA, bgB, bar;
  let currentIndex = 0;
  let bgToggle = false;
  let rafId = null;
  let visiblePhotos = photosData;
  let abortController;
  let hideUiTimer = null;
  let isNavigating = false;

  function showUI() {
    if (bar) bar.style.opacity = "1";
    if (prevBtn) prevBtn.style.opacity = "1";
    if (nextBtn) nextBtn.style.opacity = "1";
    clearTimeout(hideUiTimer);
    hideUiTimer = setTimeout(hideUI, 3000);
  }

  function hideUI() {
    if (bar) bar.style.opacity = "0";
    if (prevBtn) prevBtn.style.opacity = "0";
    if (nextBtn) nextBtn.style.opacity = "0";
  }

  function loadImage(slug) {
    const frame = document.getElementById(`film-frame-${slug}`);
    if (!frame) return;
    const img = frame.querySelector("img");
    if (img && img.dataset.src && !img.src.startsWith("http")) {
      img.src = img.dataset.src;
    }
  }

  function loadNearbyImages(idx) {
    for (let i = idx - 2; i <= idx + 2; i++) {
      const p = visiblePhotos[i];
      if (p) loadImage(p.slug);
    }
  }

  function setBackground(idx) {
    const p = visiblePhotos[idx];
    if (!p) return;
    const nextSrc = p.src;
    if (bgToggle) {
      bgB.src = nextSrc;
      bgB.style.opacity = "1";
      bgA.style.opacity = "0";
    } else {
      bgA.src = nextSrc;
      bgA.style.opacity = "1";
      bgB.style.opacity = "0";
    }
    bgToggle = !bgToggle;
  }

  function updateInfo() {
    const p = visiblePhotos[currentIndex];
    if (counter) counter.textContent = `${currentIndex + 1} / ${visiblePhotos.length}`;
    if (seriesEl && p) seriesEl.textContent = p.series || "";
  }

  function setCurrentIndex(idx) {
    if (idx === currentIndex) return;
    currentIndex = idx;
    setBackground(idx);
    updateInfo();
    loadNearbyImages(idx);
  }

  function open(slug) {
    const activeBtn = document.querySelector(".filter-btn.filter-active");
    const filter = activeBtn?.dataset?.filter;
    if (filter && filter !== "all") {
      visiblePhotos = photosData.filter((p) => p.series === filter);
      photosData.forEach((p) => {
        const frame = document.getElementById(`film-frame-${p.slug}`);
        if (frame) {
          frame.style.display = p.series === filter ? "" : "none";
        }
      });
    } else {
      visiblePhotos = photosData;
      photosData.forEach((p) => {
        const frame = document.getElementById(`film-frame-${p.slug}`);
        if (frame) frame.style.display = "";
      });
    }

    const idx = visiblePhotos.findIndex((p) => p.slug === slug);
    if (idx === -1) return;
    setCurrentIndex(idx);

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    showUI();

    requestAnimationFrame(() => {
      const frame = document.getElementById(`film-frame-${slug}`);
      if (frame) {
        track.scrollTo({ left: frame.offsetLeft - track.offsetWidth / 2 + frame.offsetWidth / 2, behavior: "instant" });
      }
      startRafLoop();
      loadNearbyImages(idx);
    });
  }

  function close() {
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    stopRafLoop();
    clearTimeout(hideUiTimer);
  }

  function goTo(idx) {
    if (idx < 0) idx = visiblePhotos.length - 1;
    if (idx >= visiblePhotos.length) idx = 0;
    isNavigating = true;
    setCurrentIndex(idx);
    const frame = document.getElementById(`film-frame-${visiblePhotos[idx].slug}`);
    if (frame) {
      track.scrollTo({
        left: frame.offsetLeft - track.offsetWidth / 2 + frame.offsetWidth / 2,
        behavior: "smooth",
      });
    }
    showUI();
  }

  function updateFrameStyles() {
    const viewCenter = track.scrollLeft + track.offsetWidth / 2;
    visiblePhotos.forEach((p) => {
      const frame = document.getElementById(`film-frame-${p.slug}`);
      if (!frame) return;
      const frameCenter = frame.offsetLeft + frame.offsetWidth / 2;
      const dist = Math.abs(frameCenter - viewCenter);
      const normalized = Math.min(1, dist / (track.offsetWidth * 0.55));
      const opacity = (1 - normalized * 1.4).toFixed(2);
      const scale = (1 - normalized * 0.35).toFixed(3);
      const inner = frame.querySelector(".film-frame-inner");
      if (inner) {
        inner.style.opacity = Math.max(0.1, opacity);
        inner.style.transform = `scale(${Math.max(0.7, scale)})`;
      }
    });
  }

  function startRafLoop() {
    stopRafLoop();
    let lastCenter = -1;
    function loop() {
      const viewCenter = track.scrollLeft + track.offsetWidth / 2;
      if (Math.abs(viewCenter - lastCenter) > 0.5) {
        lastCenter = viewCenter;
        updateFrameStyles();
        let closestIdx = currentIndex;
        let closestDist = Infinity;
        visiblePhotos.forEach((p, i) => {
          const frame = document.getElementById(`film-frame-${p.slug}`);
          if (!frame) return;
          const frameCenter = frame.offsetLeft + frame.offsetWidth / 2;
          const dist = Math.abs(viewCenter - frameCenter);
          if (dist < closestDist) { closestDist = dist; closestIdx = i; }
        });
        // Skip during programmatic navigation to prevent counter flicker
        if (!isNavigating && closestIdx >= 0 && closestIdx < visiblePhotos.length) {
          setCurrentIndex(closestIdx);
        }
      }
      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);
  }

  function stopRafLoop() {
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  function initFilmStrip() {
    if (abortController) abortController.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    overlay = document.getElementById("film-strip");
    track = document.getElementById("film-strip-track");
    closeBtn = document.getElementById("film-strip-close");
    prevBtn = document.getElementById("film-strip-prev");
    nextBtn = document.getElementById("film-strip-next");
    counter = document.getElementById("film-strip-counter");
    seriesEl = document.getElementById("film-strip-series");
    bgA = document.getElementById("film-strip-bg-a");
    bgB = document.getElementById("film-strip-bg-b");
    bar = document.getElementById("film-strip-bar");
    if (!overlay || !track) return;

    if (overlay.parentElement !== document.body) {
      document.body.appendChild(overlay);
    }

    // Open on photo click
    document.addEventListener("click", (e) => {
      const card = e.target.closest("[data-photo-id]");
      if (!card) return;
      if (overlay && overlay.classList.contains("opacity-0")) {
        e.preventDefault();
        e.stopPropagation();
        open(card.dataset.photoId);
      }
    }, { signal });

    // Close
    closeBtn?.addEventListener("click", (e) => { e.stopPropagation(); close(); }, { signal });

    // Navigation buttons
    prevBtn?.addEventListener("click", (e) => { e.stopPropagation(); goTo(currentIndex - 1); }, { signal });
    nextBtn?.addEventListener("click", (e) => { e.stopPropagation(); goTo(currentIndex + 1); }, { signal });

    // Show UI on interaction within overlay
    overlay?.addEventListener("mousemove", () => {
      if (!overlay.classList.contains("opacity-0")) showUI();
    }, { signal });
    overlay?.addEventListener("touchstart", () => {
      if (!overlay.classList.contains("opacity-0")) showUI();
    }, { signal, passive: true });

    // Keyboard
    document.addEventListener("keydown", (e) => {
      if (!overlay || overlay.classList.contains("opacity-0")) return;
      if (e.key === "Escape") { close(); }
      else if (e.key === "ArrowRight") { goTo(currentIndex + 1); }
      else if (e.key === "ArrowLeft") { goTo(currentIndex - 1); }
    }, { signal });

    // Scroll-end snap
    track.addEventListener("scrollend", () => {
      isNavigating = false;
      const center = track.scrollLeft + track.offsetWidth / 2;
      let closestIdx = currentIndex;
      let closestDist = Infinity;
      visiblePhotos.forEach((p, i) => {
        const frame = document.getElementById(`film-frame-${p.slug}`);
        if (!frame) return;
        const frameCenter = frame.offsetLeft + frame.offsetWidth / 2;
        const dist = Math.abs(center - frameCenter);
        if (dist < closestDist) { closestDist = dist; closestIdx = i; }
      });
      if (closestIdx >= 0 && closestIdx < visiblePhotos.length) {
        setCurrentIndex(closestIdx);
      }
    }, { signal });

    // Close on background click
    overlay?.addEventListener("click", (e) => {
      if (e.target === overlay || e.target === track) close();
    }, { signal });
  }

  initFilmStrip();
  document.addEventListener("astro:page-load", initFilmStrip);
</script>

<style is:global>
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }

  .film-strip-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1010;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: opacity 0.5s, background 0.15s, color 0.15s, border-color 0.15s;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .film-strip-arrow.left-4  { left: 16px; }
  .film-strip-arrow.right-4 { right: 16px; }

  .film-strip-arrow:hover {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 768px) {
    .film-strip-arrow {
      width: 48px;
      height: 48px;
    }
    .film-strip-arrow svg {
      width: 22px;
      height: 22px;
    }
    .film-strip-arrow.left-4  { left: 8px; }
    .film-strip-arrow.right-4 { right: 8px; }
  }

  @media (hover: none) and (pointer: coarse) {
    .film-strip-arrow {
      background: rgba(255, 255, 255, 0.06);
    }
  }
</style>
