---
import type { Photo } from "../../lib/photos";
import { getImage } from "astro:assets";
import { t } from "../../lib/i18n";

interface Props {
  photos: Photo[];
  locale?: string;
}

const { photos, locale = "en" } = Astro.props;

const photosData = await Promise.all(
  photos.map(async (photo) => {
    const large = await getImage({
      src: photo.data.image,
      width: 2400,
      format: "webp",
    });
    const slug = photo.id.split("/").pop()?.replace(".md", "");
    return {
      slug,
      src: large.src,
      width: large.attributes.width ?? 2400,
      height: large.attributes.height ?? 1600,
      title: photo.data.title,
      series: photo.data.series ?? "",
    };
  }),
);

const photosJson = JSON.stringify(photosData);
const i18n = {
  previous: t(locale, "filmstrip.previous"),
  next: t(locale, "filmstrip.next"),
  close: t(locale, "filmstrip.close"),
  goToPhoto: t(locale, "filmstrip.goToPhoto"),
};
const i18nJson = JSON.stringify(i18n);
---

<div
  id="film-strip"
  class="fixed inset-0 z-[999] flex flex-col bg-ink
         opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Blurred ambient backgrounds -->
  <img
    id="film-strip-bg-a"
    src=""
    alt=""
    class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700"
    style="filter: blur(70px) brightness(0.32) saturate(1.8); transform: scale(1.3); z-index: 0;"
    aria-hidden="true"
  />
  <img
    id="film-strip-bg-b"
    src=""
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700"
    style="filter: blur(70px) brightness(0.32) saturate(1.8); transform: scale(1.3); z-index: 0;"
    aria-hidden="true"
  />

  <!-- Vignette overlay -->
  <div class="absolute inset-0 pointer-events-none z-[1]" aria-hidden="true"
       style="background: radial-gradient(ellipse at center, transparent 40%, rgba(45,45,45,0.55) 100%);">
  </div>

  <!-- Horizontal scroll track -->
  <div
    id="film-strip-track"
    class="relative z-[1] flex-1 flex items-center overflow-x-auto overflow-y-hidden scrollbar-none"
    style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding: 0 10vw;"
  >
    {photosData.map((p) => (
      <div
        id={`film-frame-${p.slug}`}
        class="film-frame flex-shrink-0 w-[80vw] h-full flex items-center justify-center"
        style="scroll-snap-align: center;"
      >
        <div class="film-frame-inner flex items-center justify-center w-full">
          <img
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
            data-src={p.src}
            alt={p.title}
            class="max-h-[80vh] max-w-full object-contain select-none"
          />
        </div>
      </div>
    ))}
  </div>

  <!-- Floating edge arrows -->
  <button id="film-strip-prev" aria-label={i18n.previous} class="film-strip-arrow left-4">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 6 9 12 15 18"></polyline>
    </svg>
  </button>
  <button id="film-strip-next" aria-label={i18n.next} class="film-strip-arrow right-4">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>

  <!-- Navigation dots -->
  <div id="film-strip-dots" class="relative z-[2] flex items-center justify-center gap-2 pb-2 transition-opacity duration-500"
       style="font-family: 'Zen Kaku Gothic New', sans-serif;">
  </div>

  <!-- Bottom bar -->
  <div id="film-strip-bar" class="relative z-[2] flex-shrink-0 flex items-center justify-between px-6 h-16 border-t border-white/[0.06] transition-opacity duration-500">
    <div class="flex items-center gap-4">
      <span id="film-strip-counter" class="text-white/60 text-sm font-light tracking-widest tabular-nums"
        style="font-family: 'Zen Kaku Gothic New', sans-serif;">1 / 1</span>
      <span id="film-strip-series"
        class="text-white/35 text-sm tracking-wide truncate max-w-[40vw]"
        style="font-family: 'Caveat', cursive; font-size: 1rem;">&nbsp;</span>
    </div>
    <button id="film-strip-close"
      class="flex items-center gap-2 text-white/50 hover:text-white transition-colors text-sm font-light tracking-wide"
      style="font-family: 'Zen Kaku Gothic New', sans-serif;"
      aria-label={i18n.close}
    >
      {i18n.close}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="7" y1="7" x2="17" y2="17" />
        <line x1="17" y1="7" x2="7" y2="17" />
      </svg>
    </button>
  </div>
</div>

<script define:vars={{ photosJson, i18nJson }}>
  const photosData = JSON.parse(photosJson);
  const i18n = JSON.parse(i18nJson);
  let overlay, track, closeBtn, prevBtn, nextBtn, counter, seriesEl, bgA, bgB, bar, dots;
  let currentIndex = 0;
  let bgToggle = false;
  let rafId = null;
  let visiblePhotos = photosData;
  let abortController;
  let hideUiTimer = null;
  let isNavigating = false;
  let navFallbackTimer = null;
  const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;
  const UI_HIDE_DELAY = isTouchDevice ? 8000 : 3000;

  function showUI() {
    if (bar) bar.style.opacity = "1";
    if (dots) dots.style.opacity = "1";
    if (prevBtn) prevBtn.style.opacity = "1";
    if (nextBtn) nextBtn.style.opacity = "1";
    clearTimeout(hideUiTimer);
    hideUiTimer = setTimeout(hideUI, UI_HIDE_DELAY);
  }

  function hideUI() {
    if (bar) bar.style.opacity = "0";
    if (dots) dots.style.opacity = "0";
    if (prevBtn) prevBtn.style.opacity = "0";
    if (nextBtn) nextBtn.style.opacity = "0";
  }

  function loadImage(slug) {
    const frame = document.getElementById(`film-frame-${slug}`);
    if (!frame) return;
    const img = frame.querySelector("img");
    if (img && img.dataset.src && !img.src.startsWith("http")) {
      img.src = img.dataset.src;
    }
  }

  function loadNearbyImages(idx) {
    const len = visiblePhotos.length;
    for (let i = idx - 2; i <= idx + 2; i++) {
      const wrapped = ((i % len) + len) % len;
      const p = visiblePhotos[wrapped];
      if (p) loadImage(p.slug);
    }
  }

  function setBackground(idx) {
    const p = visiblePhotos[idx];
    if (!p) return;
    if (bgToggle) {
      bgB.src = p.src;
      bgB.style.opacity = "1";
      bgA.style.opacity = "0";
    } else {
      bgA.src = p.src;
      bgA.style.opacity = "1";
      bgB.style.opacity = "0";
    }
    bgToggle = !bgToggle;
  }

  const DOT_WINDOW = 7;
  let dotWindowStart = 0;

  function renderDots() {
    if (!dots) return;
    dots.innerHTML = "";
    const len = visiblePhotos.length;
    if (len <= 1) return;

    if (len <= 8) {
      // Show all dots
      visiblePhotos.forEach((_, i) => {
        const dot = createDot(i);
        if (i === currentIndex) dot.classList.add("active");
        dots.appendChild(dot);
      });
      dotWindowStart = 0;
    } else {
      // Sliding window
      dotWindowStart = Math.max(0, Math.min(currentIndex - 3, len - DOT_WINDOW));
      const windowEnd = Math.min(len, dotWindowStart + DOT_WINDOW);

      // Left fade hint
      if (dotWindowStart > 0) {
        const hint = createDot(dotWindowStart - 1);
        hint.classList.add("dot-fade");
        dots.appendChild(hint);
      }

      for (let i = dotWindowStart; i < windowEnd; i++) {
        const dot = createDot(i);
        if (i === currentIndex) dot.classList.add("active");
        dots.appendChild(dot);
      }

      // Right fade hint
      if (windowEnd < len) {
        const hint = createDot(windowEnd);
        hint.classList.add("dot-fade");
        dots.appendChild(hint);
      }
    }
  }

  function createDot(index) {
    const dot = document.createElement("button");
    dot.className = "film-strip-dot";
    dot.setAttribute("aria-label", i18n.goToPhoto.replace("{n}", index + 1));
    dot.addEventListener("click", () => goTo(index));
    return dot;
  }

  function refreshDotActive() {
    if (!dots) return;
    const len = visiblePhotos.length;
    if (len <= 1) return;

    if (len <= 8) {
      dots.querySelectorAll(".film-strip-dot").forEach((d, i) => {
        d.classList.toggle("active", i === currentIndex);
      });
    } else {
      // Sliding window: rebuild when active changes
      const newStart = Math.max(0, Math.min(currentIndex - 3, len - DOT_WINDOW));
      if (newStart !== dotWindowStart) {
        renderDots();
      } else {
        // Rebuild for simplicity (tiny performance cost, always correct)
        renderDots();
      }
    }
  }

  function updateInfo() {
    const p = visiblePhotos[currentIndex];
    if (counter) counter.textContent = `${currentIndex + 1} / ${visiblePhotos.length}`;
    if (seriesEl) seriesEl.textContent = p ? (p.series || "") : "";
    refreshDotActive();
  }

  function setCurrentIndex(idx) {
    if (idx === currentIndex) return;
    currentIndex = idx;
    setBackground(idx);
    updateInfo();
    loadNearbyImages(idx);
  }

  function scrollToFrame(idx) {
    const frame = document.getElementById(`film-frame-${visiblePhotos[idx].slug}`);
    if (!frame) return;
    const frameLeft = frame.offsetLeft;
    const frameWidth = frame.offsetWidth;
    const target = frameLeft - track.offsetWidth / 2 + frameWidth / 2;
    track.scrollTo({ left: target, behavior: "smooth" });
  }

  function open(slug) {
    // Reset state for fresh open
    currentIndex = 0;
    bgToggle = false;
    isNavigating = false;
    clearTimeout(navFallbackTimer);

    // Check active filter
    const activeBtn = document.querySelector(".filter-btn.filter-active");
    const filter = activeBtn?.dataset?.filter;
    if (filter && filter !== "all") {
      visiblePhotos = photosData.filter((p) => p.series === filter);
      photosData.forEach((p) => {
        const frame = document.getElementById(`film-frame-${p.slug}`);
        if (frame) {
          frame.style.display = p.series === filter ? "" : "none";
        }
      });
    } else {
      visiblePhotos = photosData;
      photosData.forEach((p) => {
        const frame = document.getElementById(`film-frame-${p.slug}`);
        if (frame) frame.style.display = "";
      });
    }

    const idx = visiblePhotos.findIndex((p) => p.slug === slug);
    if (idx === -1) return;
    renderDots();
    setCurrentIndex(idx);

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    showUI();
    history.pushState({ filmStripOpen: true }, "");

    requestAnimationFrame(() => {
      const frame = document.getElementById(`film-frame-${slug}`);
      if (frame) {
        track.scrollTo({ left: frame.offsetLeft - track.offsetWidth / 2 + frame.offsetWidth / 2, behavior: "instant" });
      }
      startRafLoop();
      loadNearbyImages(idx);
    });
  }

  function close() {
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    stopRafLoop();
    clearTimeout(hideUiTimer);
    clearTimeout(navFallbackTimer);
    isNavigating = false;
    history.replaceState(null, "");
  }

  function snapToClosest() {
    const viewCenter = track.scrollLeft + track.offsetWidth / 2;
    let closestIdx = currentIndex;
    let closestDist = Infinity;
    visiblePhotos.forEach((p, i) => {
      const frame = document.getElementById(`film-frame-${p.slug}`);
      if (!frame) return;
      if (frame.style.display === "none") return;
      const frameCenter = frame.offsetLeft + frame.offsetWidth / 2;
      const dist = Math.abs(viewCenter - frameCenter);
      if (dist < closestDist) { closestDist = dist; closestIdx = i; }
    });
    if (closestIdx >= 0 && closestIdx < visiblePhotos.length) {
      setCurrentIndex(closestIdx);
    }
  }

  function goTo(idx) {
    if (visiblePhotos.length === 0) return;
    clearTimeout(navFallbackTimer);

    // Wrap around
    if (idx < 0) idx = visiblePhotos.length - 1;
    if (idx >= visiblePhotos.length) idx = 0;

    isNavigating = true;
    setCurrentIndex(idx);
    scrollToFrame(idx);
    showUI();

    // Fallback for browsers without scrollend (Safari/iOS)
    // Must be longer than smooth scroll duration on mobile (~800ms)
    navFallbackTimer = setTimeout(() => {
      isNavigating = false;
      snapToClosest();
    }, 800);
  }

  function updateFrameStyles() {
    const viewCenter = track.scrollLeft + track.offsetWidth / 2;
    visiblePhotos.forEach((p) => {
      const frame = document.getElementById(`film-frame-${p.slug}`);
      if (!frame) return;
      if (frame.style.display === "none") return;
      const frameCenter = frame.offsetLeft + frame.offsetWidth / 2;
      const dist = Math.abs(frameCenter - viewCenter);
      const normalized = Math.min(1, dist / (track.offsetWidth * 0.55));
      const opacity = (1 - normalized * 1.4).toFixed(2);
      const scale = (1 - normalized * 0.35).toFixed(3);
      const inner = frame.querySelector(".film-frame-inner");
      if (inner) {
        inner.style.opacity = Math.max(0.1, opacity);
        inner.style.transform = `scale(${Math.max(0.7, scale)})`;
      }
    });
  }

  function startRafLoop() {
    stopRafLoop();
    let lastCenter = -1;
    function loop() {
      if (!overlay || overlay.classList.contains("opacity-0")) {
        stopRafLoop();
        return;
      }
      const viewCenter = track.scrollLeft + track.offsetWidth / 2;
      if (Math.abs(viewCenter - lastCenter) > 0.5) {
        lastCenter = viewCenter;
        updateFrameStyles();
        // Only snap when user is manually scrolling (not programmatic navigation)
        if (!isNavigating) {
          snapToClosest();
        }
      }
      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);
  }

  function stopRafLoop() {
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  function initFilmStrip() {
    if (abortController) abortController.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    // CRITICAL: Remove any stale overlay left in <body> from previous page (View Transitions)
    const existingOverlays = document.querySelectorAll("#film-strip");
    for (const el of existingOverlays) {
      if (el.parentElement === document.body && !el.isConnected) {
        el.remove();
      }
    }

    overlay = document.getElementById("film-strip");
    // If the overlay isn't the one in our current page's DOM, find the right one
    if (overlay && overlay.parentElement !== document.body) {
      // This overlay is still in the page document — it's the right one
    }

    track = document.getElementById("film-strip-track");
    closeBtn = document.getElementById("film-strip-close");
    prevBtn = document.getElementById("film-strip-prev");
    nextBtn = document.getElementById("film-strip-next");
    counter = document.getElementById("film-strip-counter");
    seriesEl = document.getElementById("film-strip-series");
    bgA = document.getElementById("film-strip-bg-a");
    bgB = document.getElementById("film-strip-bg-b");
    bar = document.getElementById("film-strip-bar");
    dots = document.getElementById("film-strip-dots");

    // Remove any leftover overlays from body (from previous View Transitions pages)
    const staleOverlays = document.body.querySelectorAll("#film-strip");
    staleOverlays.forEach((el) => {
      if (el !== overlay) el.remove();
    });

    if (!overlay || !track) return;

    // Move to body to escape stacking context
    if (overlay.parentElement !== document.body) {
      document.body.appendChild(overlay);
    }

    // Reset state
    visiblePhotos = photosData;
    currentIndex = 0;
    isNavigating = false;
    // Clear any stale display:none from previous filter
    photosData.forEach((p) => {
      const frame = document.getElementById(`film-frame-${p.slug}`);
      if (frame) frame.style.display = "";
    });

    // Open on photo click
    document.addEventListener("click", (e) => {
      const card = e.target.closest("[data-photo-id]");
      if (!card) return;
      if (overlay.classList.contains("opacity-0")) {
        e.preventDefault();
        e.stopPropagation();
        open(card.dataset.photoId);
      }
    }, { signal });

    // Close
    closeBtn?.addEventListener("click", (e) => { e.stopPropagation(); close(); }, { signal });

    // Navigation buttons
    prevBtn?.addEventListener("click", (e) => { e.stopPropagation(); if (!overlay.classList.contains("opacity-0")) goTo(currentIndex - 1); }, { signal });
    nextBtn?.addEventListener("click", (e) => { e.stopPropagation(); if (!overlay.classList.contains("opacity-0")) goTo(currentIndex + 1); }, { signal });

    // Show UI on interaction
    overlay?.addEventListener("mousemove", () => { if (!overlay.classList.contains("opacity-0")) showUI(); }, { signal });
    overlay?.addEventListener("touchstart", () => { if (!overlay.classList.contains("opacity-0")) showUI(); }, { signal, passive: true });

    // Keyboard
    document.addEventListener("keydown", (e) => {
      if (overlay.classList.contains("opacity-0")) return;
      if (e.key === "Escape") { close(); }
      else if (e.key === "ArrowRight") { goTo(currentIndex + 1); }
      else if (e.key === "ArrowLeft") { goTo(currentIndex - 1); }
    }, { signal });

    // Scroll-end snap
    track.addEventListener("scrollend", () => {
      isNavigating = false;
      clearTimeout(navFallbackTimer);
      snapToClosest();
    }, { signal });

    // Close on background click (not on photos or controls)
    overlay?.addEventListener("click", (e) => {
      if (e.target === overlay || e.target === track) close();
    }, { signal });

    // Browser back button closes overlay instead of navigating away
    window.addEventListener("popstate", () => {
      if (overlay && !overlay.classList.contains("opacity-0")) {
        overlay.classList.add("opacity-0", "pointer-events-none");
        overlay.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
        stopRafLoop();
        clearTimeout(hideUiTimer);
        clearTimeout(navFallbackTimer);
        isNavigating = false;
      }
    }, { signal });
  }

  initFilmStrip();
  document.addEventListener("astro:page-load", initFilmStrip);
</script>

<style is:global>
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }

  .film-strip-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1010;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: opacity 0.5s, background 0.15s, color 0.15s, border-color 0.15s;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .film-strip-arrow.left-4  { left: 16px; }
  .film-strip-arrow.right-4 { right: 16px; }

  .film-strip-arrow:hover {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 768px) {
    .film-strip-arrow {
      width: 48px;
      height: 48px;
    }
    .film-strip-arrow svg {
      width: 22px;
      height: 22px;
    }
    .film-strip-arrow.left-4  { left: 8px; }
    .film-strip-arrow.right-4 { right: 8px; }
  }

  @media (hover: none) and (pointer: coarse) {
    .film-strip-arrow {
      background: rgba(255, 255, 255, 0.06);
    }
  }

  /* Navigation dots */
  .film-strip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
    flex-shrink: 0;
  }

  .film-strip-dot:hover {
    background: rgba(255, 255, 255, 0.35);
  }

  .film-strip-dot.active {
    background: #7d9b76;
    transform: scale(1.5);
    box-shadow: 0 0 6px rgba(125, 155, 118, 0.4);
  }

  .film-strip-dot.dot-fade {
    width: 4px;
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .film-strip-dot {
      width: 8px;
      height: 8px;
    }
  }
</style>
