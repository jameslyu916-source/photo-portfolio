---
interface Props {
  platform: string;
  url: string;
  description: string;
  handle?: string;
  icon?: "instagram" | "threads" | "xiaohongshu";
}

const { platform, url, description, handle, icon } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex items-center gap-5 p-5 border border-border/60 rounded-sm
         hover:border-accent/30 transition-colors duration-300"
>
  <div
    class="w-10 h-10 flex items-center justify-center rounded-full
           bg-muted/5 text-muted group-hover:text-accent group-hover:bg-accent/5
           transition-colors duration-300"
  >
    {icon === "instagram" && (
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="18" cy="6" r="1" fill="currentColor" stroke="none"/></svg>
    )}
    {icon === "threads" && (
      <span class="text-base font-medium">@</span>
    )}
    {icon === "xiaohongshu" && (
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 20l4-16h2l4 16h-2l-1-4H7l-1 4H4z"/><path d="M7 14h4"/></svg>
    )}
    {!icon && (
      <span class="text-xs font-medium tracking-widest uppercase">
        {platform.slice(0, 2)}
      </span>
    )}
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline gap-2">
      <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors">
        {platform}
      </h3>
      {handle && (
        <span class="text-xs text-muted/60 font-light truncate">{handle}</span>
      )}
    </div>
    <p class="text-xs text-muted mt-0.5 leading-relaxed">{description}</p>
  </div>
  <span class="text-muted/40 text-xs group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-300 hidden sm:inline">
    &rarr;
  </span>
</a>
